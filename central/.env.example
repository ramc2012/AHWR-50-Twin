# CRMF — Centralised Rig Monitoring Facility — environment template.
# Copy to .env and set the secrets before `docker compose up`.

# --- TimescaleDB / PostgreSQL ---
# Pin a specific release for production, e.g. timescale/timescaledb:2.17.2-pg16
TIMESCALE_IMAGE=timescale/timescaledb:latest-pg15
# PGUSER is the DB OWNER / bootstrap role that creates the schema. The BACKEND itself
# connects as the least-privilege role crmf_app (audit #2 — it cannot tamper with the
# append-only audit_log); crmf_app's password is set to PGPASSWORD at DB init by
# db/app-role-password.sh. NOTE: this applies on a FRESH volume — recreate with
# `docker compose --profile demo down -v && up --build` after changing it.
PGUSER=crmf
PGPASSWORD=change-me-strong-db-password
PGDATABASE=crmf

# --- Backend ---
JWT_SECRET=change-me-long-random-jwt-secret
ADMIN_PASSWORD=admin123            # initial portal admin password (seeded once)
FLEET_SIZE=50                      # rigs seeded into the registry
CENTRAL_LATENCY_TARGET=30          # seconds; proposal target < 30 s
OFFLINE_SEC=120                    # mark a rig offline after this many seconds with no data

# Ingest auth is FAIL-CLOSED (#1): /ingest accepts a batch only if the bearer token
# matches a per-rig device token OR this global INGEST_TOKEN. A non-empty demo default
# ships so the bundled fleet-sim authenticates out of the box; the SAME value is passed
# to both the backend and the fleet-sim. In production each rig carries its own device
# token/certificate (proposal §6.3) and this global token can be retired.
INGEST_TOKEN=crmf-demo-ingest-token

# Open-ingest escape hatch (#1): if NEITHER a per-rig device token NOR INGEST_TOKEN is
# configured, /ingest still returns 401 UNLESS ALLOW_OPEN_INGEST=true AND
# NODE_ENV != production. Leave false/unset for fail-closed; never enable in production.
ALLOW_OPEN_INGEST=false

# --- Ports (host) ---
FRONTEND_PORT=8090                 # portal UI
INGEST_PORT=6000                   # backend /ingest + API (behind gateway/VPN in prod)

# --- Demo fleet simulator (only with `--profile demo`) ---
ACTIVE_RIGS=14                     # how many rigs the simulator streams
BATCH_SECONDS=10                   # store-and-forward batch cadence

# --- Windows domain / Active Directory login (AUTH contract) ---
# The portal authenticates against the ONGC Active Directory over LDAP(S), with the
# seeded local admin still available. Demo defaults below target the bundled `openldap`
# test directory (demo profile) so AD/LDAP login works out of the box; in production
# override these to point at the real Domain Controller (AD over LDAPS) and rotate the
# bind password. AUTH_MODE: local = local admin only, ldap = directory only, both = either.
AUTH_MODE=both
LDAP_URL=ldap://openldap:1389              # prod: ldaps://dc.ongc.local:636
LDAP_BIND_DN=cn=admin,dc=ongc,dc=local     # service account that can search the directory
LDAP_BIND_PASSWORD=adminpassword           # CHANGE in production
LDAP_SEARCH_BASE=ou=users,dc=ongc,dc=local # subtree searched for the login username
LDAP_SEARCH_FILTER=(|(uid={username})(cn={username})(sAMAccountName={username}))
LDAP_DOMAIN=ONGC                           # NetBIOS/UPN domain shown on the login page
LDAP_DEFAULT_ROLE=viewer                   # role for users in no mapped group (viewer|operator|admin)
# Directory group -> portal role mapping (group CN or full DN both accepted by backend):
LDAP_ROLE_ADMIN=crmf-admins
LDAP_ROLE_OPERATOR=crmf-operators
LDAP_ROLE_VIEWER=crmf-viewers
# TLS for production directories (ignored for the plain-LDAP demo):
LDAP_STARTTLS=                             # true to upgrade a plain ld:// connection via StartTLS
LDAP_TLS_REJECT_UNAUTHORIZED=false         # set true in production to enforce CA validation

# Demo test directory seed (only with `--profile demo`; bundled `openldap` service).
# Root dc=ongc,dc=local, admin bind cn=admin,dc=ongc,dc=local / LDAP_BIND_PASSWORD above.
# Default seeded logins:  driller1/Driller@123  toolpusher1/Push@123  viewer1/View@123
LDAP_ROOT=dc=ongc,dc=local
LDAP_ADMIN_USERNAME=admin
LDAP_DEMO_USERS=driller1,toolpusher1,viewer1
LDAP_DEMO_PASSWORDS=Driller@123,Push@123,View@123
LDAP_GROUP=crmf-users                      # convenience all-hands group seeded in the directory

# --- Alarm notifications (webhook/email) ---
NOTIFY_ENABLED=true                # dispatch outbound alerts on rising-edge alarms
NOTIFY_MIN_SEVERITY=P1             # notify at/above this severity (P1|P2|P3)
NOTIFY_COOLDOWN_SEC=120            # per rig+severity throttle
# Demo: seed a webhook channel pointing at the bundled notify-sink. In production,
# leave unset and configure real channels in the portal (Alarm Command Centre).
NOTIFY_DEMO_WEBHOOK_URL=http://notify-sink:9020/hook
# Email path (optional) — set SMTP_* to enable email channels:
# SMTP_HOST=                       # e.g. smtp.ongc.local
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=crmf@ongc.local
