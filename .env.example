# Copy to .env and fill in real values. NEVER commit the real .env.
# Generate strong secrets, e.g.:
#   INFLUX_TOKEN: openssl rand -hex 24
#   JWT_SECRET:   openssl rand -hex 32

# --- InfluxDB ---
INFLUX_USERNAME=admin
INFLUX_PASSWORD=CHANGE_ME_strong_password
INFLUX_ORG=romii_org
INFLUX_BUCKET=romii_bucket
INFLUX_RETENTION=30d
INFLUX_TOKEN=CHANGE_ME_influx_admin_token

# --- Backend auth ---
JWT_SECRET=CHANGE_ME_long_random_secret_min_16_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_initial_admin_password   # seeds the first admin on first boot

# --- Misc ---
DATA_SOURCE=plc          # 'mock' when running the demo profile, 'plc' for a real PLC
FRONTEND_BIND=127.0.0.1  # host interface the HMI binds. Loopback-only by default; set to
                         # the rig NIC IP to expose on the rig LAN (behind the firewall).
FRONTEND_PORT=8080       # dashboard published on ${FRONTEND_BIND}:<port>
MOCK_INTERVAL_MS=1000
CORS_ORIGIN=             # comma-separated extra browser origins; empty = same-origin only

# --- Windows domain / Active Directory login (optional) ---
# AUTH_MODE: local (default) | ldap | both. 'both' = local break-glass + domain users.
AUTH_MODE=local
LDAP_URL=                       # ldaps://dc01.corp.example.com:636  (use ldaps:// in production)
LDAP_BIND_DN=                   # service account, e.g. CN=svc-romii,OU=Service,DC=corp,DC=example,DC=com
LDAP_BIND_PASSWORD=             # service-account password (leave blank to use direct UPN bind)
LDAP_SEARCH_BASE=               # DC=corp,DC=example,DC=com
LDAP_SEARCH_FILTER=             # default (|(sAMAccountName={username})(userPrincipalName={username}))
LDAP_DOMAIN=                    # corp.example.com  (used to build user@domain UPN)
LDAP_DEFAULT_ROLE=viewer        # role for authenticated users in no mapped group
LDAP_ROLE_ADMIN=                # AD group(s) -> admin   (comma-separated CNs, e.g. RigAdmins)
LDAP_ROLE_OPERATOR=             # AD group(s) -> operator (e.g. Drillers,ToolPushers)
LDAP_ROLE_VIEWER=               # AD group(s) -> viewer
LDAP_STARTTLS=                  # true to upgrade ldap:// with StartTLS
LDAP_TLS_REJECT_UNAUTHORIZED=true   # set false ONLY for self-signed lab DCs

# --- Central facility sync (per-rig identity) ---------------------------------
# The edge image is IDENTICAL on every rig — only these vars differ per node. For a
# 3-edge fleet, set a UNIQUE DEVICE_ID and DEVICE_TOKEN on each rig and point all three
# at the SAME central /ingest endpoint. Data flow is OUTBOUND ONLY (monitoring-only).
#   rig 1:  DEVICE_ID=AHWR-01   DEVICE_TOKEN=<unique-token-1>
#   rig 2:  DEVICE_ID=AHWR-02   DEVICE_TOKEN=<unique-token-2>
#   rig 3:  DEVICE_ID=AHWR-03   DEVICE_TOKEN=<unique-token-3>
# The central must know each DEVICE_TOKEN (per-rig device token) or share one global
# INGEST_TOKEN; an unregistered token is rejected (401) and the rig shows up as
# 'pending' in the central governance workspace. The edge buffers to disk during a
# WAN/central outage (SYNC_BUFFER_DAYS) and replays oldest-first on reconnect, so the
# rig dashboard keeps working locally regardless of central availability.
SYNC_ENABLED=true
CENTRAL_URL=https://crmf.ongc.local         # central /ingest base URL (POSTs to <URL>/ingest)
DEVICE_ID=AHWR-01                           # UNIQUE per rig
DEVICE_TOKEN=CHANGE_ME_unique_per_rig_token # UNIQUE per rig; matches a central device token
SYNC_BATCH_SECONDS=10                       # batch seal cadence (lower = fresher, more WAN overhead)
SYNC_BUFFER_DAYS=15                         # store-and-forward disk buffer cap during WAN outage

# --- ETP 2.0 publisher (outbound only; optional) ------------------------------
ETP_ENABLED=false
ETP_URL=                                     # ws(s):// ETP server; blank disables
